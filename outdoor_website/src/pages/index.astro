---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const tripReports  = (await getCollection('trip-reports')).filter(p => !p.data.draft).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 2);
const recipes      = (await getCollection('recipes')).filter(p => !p.data.draft).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 2);
const gearReviews  = (await getCollection('gear-reviews')).filter(p => !p.data.draft).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 2);
const mealReviews  = (await getCollection('meal-reviews')).filter(p => !p.data.draft).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 2);
---

<Base
  title="Pack Notes — Hiking, Camping and Backpacking Tips, Tools and Trip Reports"
  description="Personal hiking, camping, and backpacking content from a California outdoor enthusiast. Trail tools, trip reports, gear reviews, and recipes."
>

  <!-- Hero -->
  <header class="bg-green-800 text-white py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="text-green-300 text-sm font-medium uppercase tracking-widest mb-4">Pack Notes</p>
      <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-5 max-w-2xl">
        Trails, trips, and the occasional calorie count.
      </h1>
      <p class="text-green-200 text-lg max-w-xl leading-relaxed mb-8">
        A California backpacker's collection of trail tools, trip reports, gear takes,
        and camp recipes. Built from stuff I wished existed before I started.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/backpacking-calorie-calculator"
          class="bg-white text-green-900 font-semibold px-6 py-3 rounded-xl hover:bg-green-50 transition-colors">
          Try the food calculator
        </a>
        <a href="/trip-reports"
          class="border border-green-500 text-white font-semibold px-6 py-3 rounded-xl hover:bg-green-700 transition-colors">
          Read trip reports
        </a>
      </div>
    </div>
  </header>

  <div class="max-w-4xl mx-auto px-6 py-14 space-y-16">

    <!-- About -->
    <section class="grid sm:grid-cols-2 gap-10 items-start">
      <div>
        <h2 class="text-2xl font-bold text-stone-900 mb-4">About this site</h2>
        <p class="text-stone-600 leading-relaxed mb-4">
          I grew up in the Midwest and moved out to California, where I got properly hooked on the mountains.
          Most of what's here came out of questions I kept running into: how much food do I actually need,
          what gear is worth buying, which routes are worth doing twice.
        </p>
        <p class="text-stone-600 leading-relaxed">
          Not a gear sponsorship machine or an affiliate empire. Just a place to put useful things and
          notes from the trail.
        </p>
      </div>
      <div class="bg-stone-50 rounded-2xl p-6 space-y-3">
        <p class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-4">What you'll find here</p>
        {[
          { icon: '🧮', label: 'Trail tools', desc: 'Calculators for food, pack weight, and trip planning' },
          { icon: '🗺️', label: 'Trip reports', desc: 'Routes I\'ve done with honest notes on conditions' },
          { icon: '🍲', label: 'Camp recipes', desc: 'Real meals with actual calorie counts' },
          { icon: '🎒', label: 'Gear reviews', desc: 'What works and what I wouldn\'t buy again' },
        ].map(item => (
          <div class="flex gap-3 items-start">
            <span class="text-xl mt-0.5">{item.icon}</span>
            <div>
              <p class="font-semibold text-stone-800 text-sm">{item.label}</p>
              <p class="text-stone-500 text-xs">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Featured tool -->
    <section>
      <h2 class="text-xl font-bold text-stone-900 mb-5">Featured Tool</h2>
      <a href="/backpacking-calorie-calculator"
        class="block bg-green-800 text-white rounded-2xl p-8 hover:bg-green-900 transition-colors">
        <p class="text-green-300 text-xs font-semibold uppercase tracking-widest mb-2">Calculator</p>
        <h3 class="text-2xl font-bold mb-2">Backpacking Food Calculator</h3>
        <p class="text-green-200 max-w-xl">
          How much food do you actually need? Enter your miles, elevation, pack weight, and temperature.
          Get a calorie target with a full breakdown of where the numbers come from.
        </p>
        <p class="mt-4 text-sm font-semibold text-green-300">Open calculator →</p>
      </a>
    </section>

    <!-- Recent content -->
    {tripReports.length > 0 && (
      <section>
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-xl font-bold text-stone-900">Recent Trip Reports</h2>
          <a href="/trip-reports" class="text-sm text-green-700 hover:underline">All reports</a>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          {tripReports.map(post => (
            <a href={`/trip-reports/${post.slug}`}
              class="block bg-white border border-stone-200 rounded-xl p-5 hover:border-green-400 hover:shadow-sm transition-all">
              <h3 class="font-semibold text-stone-900 mb-1">{post.data.title}</h3>
              <p class="text-stone-500 text-xs mb-2">{post.data.location}</p>
              <p class="text-stone-600 text-sm">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    {recipes.length > 0 && (
      <section>
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-xl font-bold text-stone-900">Recent Recipes</h2>
          <a href="/recipes" class="text-sm text-green-700 hover:underline">All recipes</a>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          {recipes.map(post => (
            <a href={`/recipes/${post.slug}`}
              class="block bg-white border border-stone-200 rounded-xl p-5 hover:border-green-400 hover:shadow-sm transition-all">
              <h3 class="font-semibold text-stone-900 mb-1">{post.data.title}</h3>
              {post.data.calories && <p class="text-green-700 text-xs font-medium mb-2">{post.data.calories} cal</p>}
              <p class="text-stone-600 text-sm">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    {gearReviews.length > 0 && (
      <section>
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-xl font-bold text-stone-900">Recent Gear Reviews</h2>
          <a href="/gear-reviews" class="text-sm text-green-700 hover:underline">All reviews</a>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          {gearReviews.map(post => (
            <a href={`/gear-reviews/${post.slug}`}
              class="block bg-white border border-stone-200 rounded-xl p-5 hover:border-green-400 hover:shadow-sm transition-all">
              <h3 class="font-semibold text-stone-900 mb-1">{post.data.title}</h3>
              <p class="text-amber-500 text-xs mb-2">{'★'.repeat(post.data.rating)}{'☆'.repeat(5 - post.data.rating)}</p>
              <p class="text-stone-600 text-sm">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    {mealReviews.length > 0 && (
      <section class="pb-4">
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-xl font-bold text-stone-900">Recent Meal Reviews</h2>
          <a href="/meal-reviews" class="text-sm text-green-700 hover:underline">All reviews</a>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          {mealReviews.map(post => (
            <a href={`/meal-reviews/${post.slug}`}
              class="block bg-white border border-stone-200 rounded-xl p-5 hover:border-green-400 hover:shadow-sm transition-all">
              <h3 class="font-semibold text-stone-900 mb-1">{post.data.title}</h3>
              <p class="text-amber-500 text-xs mb-2">{'★'.repeat(post.data.rating)}{'☆'.repeat(5 - post.data.rating)}</p>
              <p class="text-stone-600 text-sm">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>

</Base>
