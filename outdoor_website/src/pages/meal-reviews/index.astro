---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('meal-reviews'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function stars(n: number) {
  return '★'.repeat(n) + '☆'.repeat(5 - n);
}
---

<Base title="Backpacking Meal Reviews | Trail Provisions" description="Honest reviews of freeze-dried meals, bars, and trail food.">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-stone-900 mb-2">Meal Reviews</h1>
    <p class="text-stone-500 mb-10">Honest takes on freeze-dried meals, bars, and packaged trail food — rated on taste, calories, weight, and value.</p>

    {posts.length === 0 && (
      <p class="text-stone-400 italic">No reviews yet — check back soon.</p>
    )}

    <div class="space-y-5">
      {posts.map(post => (
        <a href={`/meal-reviews/${post.slug}`} class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-green-400 hover:shadow-sm transition-all">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="font-bold text-lg text-stone-900">{post.data.title}</h2>
              {post.data.brand && <p class="text-stone-400 text-xs mt-0.5">{post.data.brand}</p>}
              <p class="text-amber-500 text-base mt-1">{stars(post.data.rating)}</p>
              <p class="text-stone-600 mt-2 text-sm">{post.data.description}</p>
              <div class="flex flex-wrap gap-2 mt-3">
                {post.data.calories && <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">{post.data.calories} cal</span>}
                {post.data.price && <span class="text-xs bg-stone-100 text-stone-600 px-2 py-1 rounded-full">${post.data.price.toFixed(2)}</span>}
              </div>
            </div>
            <span class="text-green-600 text-sm shrink-0 mt-1">Read →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
