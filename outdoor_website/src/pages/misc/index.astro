---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('misc'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="More | Pack Notes" description="Guides, tips, and miscellaneous outdoor content.">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-stone-900 mb-2">More</h1>
    <p class="text-stone-500 mb-10">Guides, planning tips, and everything else that doesn't fit neatly in a box.</p>

    {posts.length === 0 && (
      <p class="text-stone-400 italic">Nothing here yet — check back soon.</p>
    )}

    <div class="space-y-5">
      {posts.map(post => (
        <a href={`/misc/${post.slug}`} class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-green-400 hover:shadow-sm transition-all">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="font-bold text-lg text-stone-900">{post.data.title}</h2>
              <p class="text-stone-500 text-xs mt-1">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
              <p class="text-stone-600 mt-2 text-sm">{post.data.description}</p>
            </div>
            <span class="text-green-600 text-sm shrink-0 mt-1">Read →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
