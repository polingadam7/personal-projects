---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('recipes'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Backpacking Recipes | Toward Outdoors" description="Trail-tested backpacking meal recipes with calorie counts and prep times.">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-stone-900 mb-2">Recipes</h1>
    <p class="text-stone-500 mb-10">Calorie-dense trail meals you can actually make — from simple upgrades to full dehydrated dinners.</p>

    {posts.length === 0 && (
      <p class="text-stone-400 italic">No recipes yet — check back soon.</p>
    )}

    <div class="grid sm:grid-cols-2 gap-5">
      {posts.map(post => (
        <a href={`/recipes/${post.slug}`} class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-green-400 hover:shadow-sm transition-all">
          <h2 class="font-bold text-lg text-stone-900 mb-1">{post.data.title}</h2>
          <p class="text-stone-500 text-xs mb-2">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</p>
          <p class="text-stone-600 text-sm mb-3">{post.data.description}</p>
          <div class="flex flex-wrap gap-2">
            {post.data.calories && <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">{post.data.calories} cal</span>}
            {post.data.prepTime && <span class="text-xs bg-stone-100 text-stone-600 px-2 py-1 rounded-full">⏱ {post.data.prepTime}</span>}
            {post.data.servings && <span class="text-xs bg-stone-100 text-stone-600 px-2 py-1 rounded-full">Serves {post.data.servings}</span>}
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
