---
import PostLayout from '../../layouts/PostLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('trip-reports');
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const meta = [
  post.data.location  && { label: 'Location',   value: post.data.location },
  post.data.days      && { label: 'Days',        value: String(post.data.days) },
  post.data.miles     && { label: 'Miles',       value: String(post.data.miles) },
  post.data.difficulty && { label: 'Difficulty', value: post.data.difficulty },
].filter(Boolean) as { label: string; value: string }[];
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  backHref="/trip-reports"
  backLabel="All Trip Reports"
  meta={meta}
>
  <Content />
</PostLayout>
