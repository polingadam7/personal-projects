---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('trip-reports'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Trip Reports | Trail Provisions" description="Backpacking and hiking trip reports from the field.">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-stone-900 mb-2">Trip Reports</h1>
    <p class="text-stone-500 mb-10">Notes from the trail — routes, conditions, and lessons learned.</p>

    {posts.length === 0 && (
      <p class="text-stone-400 italic">No trip reports yet — check back soon.</p>
    )}

    <div class="space-y-5">
      {posts.map(post => (
        <a href={`/trip-reports/${post.slug}`} class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-green-400 hover:shadow-sm transition-all">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="font-bold text-lg text-stone-900 group-hover:text-green-700">{post.data.title}</h2>
              <p class="text-stone-500 text-sm mt-1">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
              <p class="text-stone-600 mt-2 text-sm">{post.data.description}</p>
              <div class="flex flex-wrap gap-2 mt-3">
                {post.data.location && <span class="text-xs bg-stone-100 text-stone-600 px-2 py-1 rounded-full">📍 {post.data.location}</span>}
                {post.data.days && <span class="text-xs bg-stone-100 text-stone-600 px-2 py-1 rounded-full">{post.data.days} days</span>}
                {post.data.miles && <span class="text-xs bg-stone-100 text-stone-600 px-2 py-1 rounded-full">{post.data.miles} miles</span>}
                {post.data.difficulty && <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full capitalize">{post.data.difficulty}</span>}
              </div>
            </div>
            <span class="text-green-600 text-sm shrink-0 mt-1">Read →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
